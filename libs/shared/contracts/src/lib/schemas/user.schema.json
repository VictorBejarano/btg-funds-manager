{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "El UID proveniente de Firebase Auth"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "displayName": {
      "type": "string"
    },
    "photoURL": {
      "type": ["string", "null"]
    },
    "role": {
      "type": "string",
      "enum": ["ADMIN", "USER", "GUEST"],
      "default": "USER"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO String de la fecha de creación"
    }
  },
  "required": ["id", "email", "role"]
}
