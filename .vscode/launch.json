{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "flutter-app",
      "cwd": "apps\\flutter-app",
      "request": "launch",
      "type": "dart"
    },
    {
      "name": "flutter-app (profile mode)",
      "cwd": "apps\\flutter-app",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile"
    },
    {
      "name": "flutter-app (release mode)",
      "cwd": "apps\\flutter-app",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release"
    },
    {
      "name": "mobile-core",
      "cwd": "libs\\mobile-core",
      "request": "launch",
      "type": "dart"
    },
    {
      "name": "mobile-core (profile mode)",
      "cwd": "libs\\mobile-core",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile"
    },
    {
      "name": "mobile-core (release mode)",
      "cwd": "libs\\mobile-core",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug btg-manager-api with Nx",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["nx", "serve", "btg-manager-api"],
      "env": {
        "NODE_OPTIONS": "--inspect=9229"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/btg-manager-api/dist/**/*.(m|c|)js",
        "!**/node_modules/**"
      ]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug apps/btg-manager-api with Nx",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["nx", "serve", "apps/btg-manager-api"],
      "env": {
        "NODE_OPTIONS": "--inspect=9230"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/apps/btg-manager-api/dist/**/*.(m|c|)js",
        "!**/node_modules/**"
      ]
    }
  ]
}
